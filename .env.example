# App
MMP_APP_URL=http://localhost:3000
MMP_DEFAULT_LOCALE=fr-MA
MMP_SUPPORTED_LOCALES=fr-MA,ar-MA,en-US

# MongoDB Atlas — whitelist your build server's IP:
# https://www.mongodb.com/docs/atlas/security-whitelist/
MONGO_URI=
MONGO_DB_NAME=mmpharma

# Cloudinary — https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=
CLOUDINARY_UPLOAD_PRESET=

# DeepSeek (hidden SEO) — https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Sentry (optional) — https://sentry.io/
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Upstash Redis (optional) — https://upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
